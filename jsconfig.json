{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2021",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "moduleResolution": "Bundler"
  },
  "include": ["**/*.js", "**/*.d.ts"],
  "exclude": ["_site", ".jekyll-cache", "node_modules"]
}
